syntax on
set nocompatible
set encoding=utf-8
set number
set relativenumber
set scrolloff=8
set signcolumn=yes
set hidden
set tabstop=4
set shiftwidth=4
set expandtab
set smartindent
set autoindent
set nowrap
set list
set ignorecase
set smartcase
set incsearch
set hlsearch
nnoremap <leader>h :nohlsearch<CR>
set nobackup
let mapleader=" "
set termguicolors
colorscheme slate
set cursorline
